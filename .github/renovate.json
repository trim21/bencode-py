{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "local>trim21/renovate-config",
    "local>trim21/renovate-config:monthly"
  ],
  "rebaseWhen": "conflicted",
  "git-submodules": {
    "enabled": true
  },
  "poetry": {
    "enabled": false
  },
  "labels": [
    "ci:auto-merge",
    "dependencies"
  ],
  "prConcurrentLimit": 3
}
